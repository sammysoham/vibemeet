{
  "name": "vibemeet",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "lint": "npm run lint --workspace client",
    "db:generate": "npm run prisma:generate --workspace server",
    "db:migrate": "npm run prisma:migrate --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
